# Copy to .env.local for local dev (or .env for docker compose) — never commit real values.

# --- Database (Postgres + Drizzle) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/redsrrc

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email (Resend) — leave blank locally; submissions still persist to Postgres ---
RESEND_API_KEY=
RESEND_FROM_EMAIL="Red's RRC <notifications@redsrrc.com>"
LEADS_NOTIFICATION_EMAIL=info@redsrrc.com

# --- Admin dashboard auth (jose-based stateless sessions) ---
AUTH_SECRET=
ADMIN_EMAIL=admin@redsrrc.com
ADMIN_PASSWORD=

# --- Optional integrations ---
NEXT_PUBLIC_BOOKING_URL=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Object storage (MinIO / S3-compatible) for project gallery images ---
# Internal endpoint for the S3 client (use http://minio:9000 in Docker)
S3_ENDPOINT=http://localhost:9000
# Public base URL for <img src> (use http://localhost:9000 for local dev)
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=redsrrc-projects
S3_REGION=us-east-1
# MinIO root credentials (used by docker-compose minio-init to create the bucket)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
