# Copy to .env.local for local dev (or .env for docker compose) — never commit real values.

# --- Database (Postgres + Drizzle) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/redsrrc

# --- Site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email (Resend) — leave blank locally; submissions still persist to Postgres ---
RESEND_API_KEY=
RESEND_FROM_EMAIL="Red's RRC <notifications@redsrrc.com>"
LEADS_NOTIFICATION_EMAIL=info@redsrrc.com

# --- Admin dashboard auth (Auth.js Credentials provider) ---
AUTH_SECRET=
AUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@redsrrc.com
# bcrypt hash of the admin password — generate with `npm run hash:password -- "yourpassword"`
ADMIN_PASSWORD_HASH=

# --- Optional integrations (see start/rebuild/integrations-plan.md) ---
NEXT_PUBLIC_BOOKING_URL=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
